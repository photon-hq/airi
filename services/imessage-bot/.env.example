# Photon iMessage server configuration
# Your Photon Spectrum server URL (e.g. https://<subdomain>.photon.codes or local dev server)
IMESSAGE_SERVER_URL=http://localhost:1234
# API key for the Photon server (configured in your Photon dashboard)
IMESSAGE_API_KEY=

# AIRI server-runtime connection
# Authentication token for the AIRI WebSocket server
AIRI_TOKEN=
# WebSocket URL of the AIRI server-runtime
AIRI_URL=ws://localhost:6121/ws

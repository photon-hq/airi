# Photon iMessage server configuration
# Your Photon Spectrum server URL (e.g. https://<subdomain>.photon.codes or local dev server)
IMESSAGE_SERVER_URL=http://localhost:1234
# API key for the Photon server (configured in your Photon dashboard)
IMESSAGE_API_KEY=

# AIRI server-runtime connection
# Authentication token for the AIRI WebSocket server
AIRI_TOKEN=
# WebSocket URL of the AIRI server-runtime
AIRI_URL=ws://localhost:6121/ws

# --- Audio message support (STT + TTS) ---

# Speech-to-Text (STT) for receiving voice messages
# Set to 'true' to enable transcription of incoming audio messages
IMESSAGE_STT_ENABLED=false
# OpenAI-compatible STT API key
IMESSAGE_STT_API_KEY=
# OpenAI-compatible STT API base URL (e.g. https://api.openai.com/v1)
IMESSAGE_STT_API_BASE_URL=
# STT model name (e.g. 'whisper-1')
IMESSAGE_STT_MODEL=whisper-1

# Text-to-Speech (TTS) for sending voice messages
# Set to 'true' to send AI responses as audio messages
IMESSAGE_TTS_ENABLED=false
# TTS provider: 'kokoro' (default, local), 'openai', or 'elevenlabs'
IMESSAGE_TTS_PROVIDER=kokoro
# TTS API key (needed for 'openai' and 'elevenlabs' providers)
IMESSAGE_TTS_API_KEY=
# TTS API base URL (needed for 'openai' and 'elevenlabs' providers)
# For OpenAI: https://api.openai.com/v1
# For ElevenLabs: https://unspeech.hyp3r.link/v1/ (unspeech proxy)
IMESSAGE_TTS_API_BASE_URL=
# TTS model name (needed for 'openai' and 'elevenlabs' providers)
# OpenAI: 'tts-1', 'tts-1-hd', 'gpt-4o-mini-tts'
# ElevenLabs: 'eleven_multilingual_v2', 'eleven_flash_v2_5', 'eleven_turbo_v2_5', etc.
IMESSAGE_TTS_MODEL=
# TTS voice
# Kokoro voices (American Female): 'af_heart' (default), 'af_bella', 'af_sky', 'af_nicole', 'af_nova', 'af_sarah', etc.
# Kokoro voices (American Male): 'am_adam', 'am_echo', 'am_eric', etc.
# Kokoro voices (British): 'bf_emma', 'bf_isabella', 'bf_alice', 'bf_lily', 'bm_george', 'bm_lewis', etc.
# OpenAI: 'alloy', 'ash', 'coral', 'echo', 'fable', 'nova', 'onyx', 'sage', 'shimmer'
# ElevenLabs: Use voice IDs from the ElevenLabs dashboard (e.g. 'EXAVITQu4vr4xnSDxMaL' for Bella)
IMESSAGE_TTS_VOICE=af_heart
# Speech speed multiplier (0.25 to 4.0, default 1.0)
# Values above 1.0 sound more energetic; 1.1-1.2 works well for anime characters
IMESSAGE_TTS_SPEED=1.0
# Voice instructions for gpt-4o-mini-tts — OpenAI only, ignored by Kokoro
IMESSAGE_TTS_INSTRUCTIONS=
# Kokoro ONNX model quantization (only used when provider is 'kokoro')
# Options: 'fp32' (best quality), 'fp16', 'q8' (good balance), 'q4', 'q4f16' (smallest/fastest)
# The model (~160MB for q8) is downloaded from HuggingFace on first use and cached locally.
IMESSAGE_TTS_KOKORO_QUANTIZATION=q8

# --- ElevenLabs-specific settings (only used when provider is 'elevenlabs') ---
# Voice stability (0.0 to 1.0, default 0.5). Higher = more consistent but monotone.
IMESSAGE_TTS_ELEVENLABS_STABILITY=0.5
# Voice similarity boost (0.0 to 1.0, default 0.75). Higher = closer to original voice.
IMESSAGE_TTS_ELEVENLABS_SIMILARITY_BOOST=0.75
# Style exaggeration (0.0 to 1.0, default 0). Amplifies voice style. Increases latency.
IMESSAGE_TTS_ELEVENLABS_STYLE=0
# Speaker boost (true/false, default true). Enhances clarity at cost of latency.
IMESSAGE_TTS_ELEVENLABS_SPEAKER_BOOST=true

# Set to 'true' to also send the text alongside the audio message
IMESSAGE_TTS_SEND_TEXT_ALONGSIDE=false
